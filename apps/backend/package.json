{
  "name": "backend",
  "version": "0.1.0",
  "description": "MCP server for TM modeling and DDD aggregate visualization",
  "private": true,
  "license": "MIT",
  "main": "dist/main-http.js",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch --entryFile main-http",
    "start:dev:stdio": "nest start --watch --entryFile main-stdio",
    "start:dev:http": "nest start --watch --entryFile main-http",
    "start:prod:stdio": "node dist/main-stdio",
    "start:prod:http": "node dist/main-http",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/platform-ws": "^11.1.26",
    "@nestjs/websockets": "^11.1.26",
    "@rekog/mcp-nest": "^1.9.10",
    "nanoid": "^5.1.11",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.36.0",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@types/express": "^5.0.6",
    "@types/node": "^24.6.2",
    "@types/ws": "^8.5.13",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^16.4.0",
    "prettier": "^3.8.4",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1"
  },
  "engines": {
    "node": ">=20"
  }
}
